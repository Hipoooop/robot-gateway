{
  "id": "openclaw-wf",
  "name": "Wildfire IM",
  "version": "1.0.0",
  "description": "Wildfire IM channel for OpenClaw",
  "author": "Wildfire IM Team",
  "channels": [
    "wildfire"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean", "default": true },
      "gatewayUrl": { "type": "string", "default": "" },
      "robotId": { "type": "string", "default": "" },
      "robotSecret": { "type": "string", "default": "" },
      "asrServer": { "type": "string", "default": "" },
      "requireMention": { "type": "boolean", "default": true },
      "helpKeywords": { "type": "string", "default": "帮,请,分析,总结" },
      "accounts": {
        "type": "object",
        "default": {},
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "gatewayUrl": { "type": "string", "default": "" },
            "robotId": { "type": "string", "default": "" },
            "robotSecret": { "type": "string", "default": "" },
            "asrServer": { "type": "string", "default": "" },
            "requireMention": { "type": "boolean", "default": true }
          }
        }
      },
      "userCache": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "redisUrl": { "type": "string", "default": "redis://localhost:6379" },
          "fields": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        }
      }
    }
  },
  "channelConfigs": {
    "wildfire": {
      "label": "Wildfire IM",
      "description": "Wildfire IM protocol channel via @wildfirechat/robot-gateway-client-sdk",
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "gatewayUrl": { "type": "string", "default": "" },
          "robotId": { "type": "string", "default": "" },
          "robotSecret": { "type": "string", "default": "" },
          "asrServer": { "type": "string", "default": "" },
          "requireMention": { "type": "boolean", "default": true },
          "helpKeywords": { "type": "string", "default": "帮,请,分析,总结" },
          "accounts": {
            "type": "object",
            "default": {},
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean", "default": true },
                "gatewayUrl": { "type": "string", "default": "" },
                "robotId": { "type": "string", "default": "" },
                "robotSecret": { "type": "string", "default": "" },
                "asrServer": { "type": "string", "default": "" },
                "requireMention": { "type": "boolean", "default": true }
              }
            }
          },
          "userCache": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "redisUrl": { "type": "string", "default": "redis://localhost:6379" },
              "fields": {
                "type": "array",
                "items": { "type": "string" },
                "default": []
              }
            }
          }
        }
      },
      "uiHints": {
        "gatewayUrl": { "label": "Gateway URL", "placeholder": "ws://localhost:8884/robot/gateway" },
        "robotId": { "label": "Robot ID" },
        "robotSecret": { "label": "Robot Secret", "sensitive": true },
        "asrServer": { "label": "ASR Server", "placeholder": "http://localhost:8080/asr" },
        "requireMention": { "label": "Require Mention in Group" },
        "helpKeywords": { "label": "Help Keywords" }
      }
    }
