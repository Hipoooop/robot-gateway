{
  "wildfire": {
    "gateway": {
      "url": "ws://localhost:8884/robot/gateway",
      "robotId": "your-robot-id",
      "robotSecret": "your-robot-secret"
    }
  },
  "plugin": {
    "server": {
      "host": "0.0.0.0",
      "port": 18080,
      "authToken": "your-secret-auth-token"
    },
    "group": {
      "enabled": true,
      "respondOnMention": true,
      "respondOnQuestion": true,
      "helpKeywords": "帮,请,分析,总结,怎么,如何",
      "allowedIds": []
    },
    "whitelist": {
      "enabled": false,
      "allowedUsers": [],
      "allowedGroups": []
    },
    "file": {
      "enabled": true,
      "allowedTypes": ["image", "video", "audio", "file"],
      "maxSize": 100
    }
  }
}
