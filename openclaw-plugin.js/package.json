{
  "name": "@wildfirechat/openclaw-wf",
  "version": "1.0.5",
  "description": "Wildfire IM channel plugin for OpenClaw",
  "license": "MIT",
  "author": "Wildfire IM Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wildfirechat/robot-gateway.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "openclaw-wf",
      "label": "Wildfire IM",
      "selectionLabel": "Wildfire IM",
      "docsPath": "/channels/wildfire",
      "blurb": "Wildfire IM protocol channel via @wildfirechat/robot-gateway-client-sdk",
      "order": 87,
      "aliases": [
        "wildfire",
        "wf"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@wildfirechat/robot-gateway-client-sdk": "^1.0.4",
    "@wildfirechat/server-sdk": "^1.0.2"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.26"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
